# ===== LLM (Azure OpenAI 형식 사내 게이트웨이) =====
# 키는 api-key 헤더 값 (atl-...). OPENAI_MODEL/EMBEDDING_MODEL = Azure deployment 이름.
OPENAI_API_KEY=atl-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 아래 3개는 config.py에 기본값이 있어 보통 생략 가능 (필요 시 override)
# AZURE_OPENAI_ENDPOINT=https://skax.ai-talentlab.com
# OPENAI_API_VERSION=2024-12-01-preview
# OPENAI_CA_BUNDLE=/app/certs/sk-ca.pem   # 사내 자기서명 CA 신뢰용

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===== Milvus =====
# 로컬 직접 실행 시: localhost / 컨테이너 실행 시: milvus (compose 서비스명)
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=documents

# ===== Checkpointer (대화 영속화) =====
# 컨테이너 실행 시: postgres (compose 서비스명)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=agents
