# ===== LLM =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===== Milvus =====
# 로컬 직접 실행 시: localhost / 컨테이너 실행 시: milvus (compose 서비스명)
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=documents

# ===== Checkpointer (대화 영속화) =====
# 컨테이너 실행 시: postgres (compose 서비스명)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=agents

# ===== Frontend =====
# 컨테이너 내부 통신은 서비스명(be), 로컬은 localhost
BACKEND_URL=http://be:8000
